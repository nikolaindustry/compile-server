# Copy this to .env and fill in your values
# DO NOT commit .env to git

# Shared secret between this server and Supabase edge functions
HYPERWISOR_SECRET=your_strong_random_secret_here

# Supabase project URL (from Supabase dashboard → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service_role key (NOT the anon key — has full DB access)
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Port (Render sets this automatically)
PORT=3000
